# LUNGA — Environment Variables
# Copy this file to .env and fill in your credentials.
# Get these from: payfast.io → Settings → Integration

# PayFast Credentials (from your PayFast dashboard)
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=your_merchant_key_here
PAYFAST_PASSPHRASE=your_passphrase_here

# Set to "true" when testing with PayFast sandbox
PAYFAST_SANDBOX=false

# Your live domain (where the ITN webhook lives)
ITN_URL=https://lunga.co.za/api/itn

# A random secret string for signing unlock tokens (generate one: openssl rand -hex 32)
UNLOCK_SECRET=change-this-to-a-long-random-string

# Cloudflare KV namespace (set in wrangler.toml, not here)
# LUNGA_KV = your_kv_binding
